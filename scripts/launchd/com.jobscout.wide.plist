<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jobscout.wide</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__SCOUT_DIR__/scripts/run_pipeline.sh</string>
    <string>wide</string>
  </array>

  <!-- Nightly at 2:00am -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>2</integer>
    <key>Minute</key><integer>0</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>__SCOUT_DIR__/logs/launchd-wide.out.log</string>
  <key>StandardErrorPath</key>
  <string>__SCOUT_DIR__/logs/launchd-wide.err.log</string>
</dict>
</plist>
